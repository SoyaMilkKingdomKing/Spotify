# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key or secret server key. Do not use NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY here.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spotify Developer App
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_REFRESH_TOKEN=your-one-time-oauth-refresh-token

# Automation
AUTOMATION_TIMEZONE=America/Toronto
RUN_LOCAL_HOUR=6
TARGET_TRACK_COUNT=30
DEFAULT_MARKET=CA
PLAYLIST_PUBLIC=false

# Comma-separated scenario IDs.
SCENARIOS=late_night_drive,emo,love_songs,fast_paced

# Leave false by default because Spotify currently marks Audio Features as deprecated.
ENABLE_SPOTIFY_AUDIO_FEATURES=false
